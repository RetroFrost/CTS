<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.retrofrost.CTS</id>
  <name>CTS</name>
  <summary>Create scrolling comparison videos</summary>

  <developer id="io.github.retrofrost">
    <name>StarterFreaks</name>
  </developer>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>CC0-1.0</project_license>

  <description>
    <p>
      CTS is a desktop editor for building continuously scrolling comparison
      videos from visual cards and spreadsheet data.
    </p>
    <p>
      Edit the rendered preview directly, import CSV or XLSX data, arrange
      images, mix soundtrack layers, and export H.264/AAC MP4 video through
      FFmpeg.
    </p>
  </description>

  <launchable type="desktop-id">io.github.retrofrost.CTS.desktop</launchable>
  <provides>
    <binary>comparison-timeline-studio</binary>
  </provides>

  <url type="homepage">https://github.com/RetroFrost/CTS</url>
  <url type="bugtracker">https://github.com/RetroFrost/CTS/issues</url>
  <url type="vcs-browser">https://github.com/RetroFrost/CTS</url>

  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
    <category>Graphics</category>
  </categories>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.4.5" date="2026-07-14">
      <description>
        <p>
          Introduced the redesigned editing workspace, CSV/XLSX import, live
          text and image transforms, optional hexagons, expanded visual
          controls, and improved soundtrack export.
        </p>
      </description>
    </release>
  </releases>
</component>
