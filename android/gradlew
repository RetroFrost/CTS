#!/usr/bin/env sh
set -eu

GRADLE_VERSION="8.13"
CACHE_ROOT="${GRADLE_USER_HOME:-$HOME/.gradle}/cts-wrapper"
GRADLE_HOME="$CACHE_ROOT/gradle-$GRADLE_VERSION"
ARCHIVE="$CACHE_ROOT/gradle-$GRADLE_VERSION-bin.zip"

if [ ! -x "$GRADLE_HOME/bin/gradle" ]; then
    mkdir -p "$CACHE_ROOT"
    if [ ! -f "$ARCHIVE" ]; then
        URL="https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-bin.zip"
        if command -v curl >/dev/null 2>&1; then
            curl -fL "$URL" -o "$ARCHIVE"
        elif command -v wget >/dev/null 2>&1; then
            wget -O "$ARCHIVE" "$URL"
        else
            echo "CTS Android needs curl or wget to download Gradle $GRADLE_VERSION." >&2
            exit 1
        fi
    fi
    command -v unzip >/dev/null 2>&1 || {
        echo "Install unzip first: sudo apt install unzip" >&2
        exit 1
    }
    unzip -q -o "$ARCHIVE" -d "$CACHE_ROOT"
fi

exec "$GRADLE_HOME/bin/gradle" "$@"
